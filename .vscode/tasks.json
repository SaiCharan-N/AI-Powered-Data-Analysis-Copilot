{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Backend: install dependencies",
      "type": "shell",
      "command": ".venv\\Scripts\\python.exe -m pip install -r requirements.txt",
      "problemMatcher": []
    },
    {
      "label": "Backend: run FastAPI",
      "type": "shell",
      "command": ".venv\\Scripts\\python.exe -m uvicorn app.main:app --reload --host 127.0.0.1 --port 8000",
      "isBackground": true,
      "problemMatcher": []
    },
    {
      "label": "Frontend: install dependencies",
      "type": "shell",
      "command": "npm install",
      "problemMatcher": []
    },
    {
      "label": "Frontend: run Vite",
      "type": "shell",
      "command": "npm run dev -- --port 5173",
      "isBackground": true,
      "problemMatcher": []
    },
    {
      "label": "Build: frontend",
      "type": "shell",
      "command": "npm run build",
      "problemMatcher": []
    }
  ]
}
